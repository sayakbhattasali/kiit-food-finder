<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme: dark, no action bar, edge-to-edge ready -->
    <style name="Theme.KIITFoodFinder" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">#0D0D0F</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Splash screen theme for Android 12+ compatibility -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D0D0F</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.KIITFoodFinder</item>
    </style>
</resources>
